# Shaarada Koota Montessori ERP
# Copy values into:
# - .env.local for local development
# - .env.production for production-like or live database work
#
# Runtime env strategy:
# - local/dev commands load .env.local
# - production/live commands load .env.production
# - .env is intentionally not used anywhere

# Local or production MySQL connection used by Prisma application runtime.
DATABASE_URL="mysql://user:password@host:3306/database_name"

# Direct MySQL connection used by Prisma CLI operations such as db push.
DIRECT_URL="mysql://user:password@host:3306/database_name"

# Public application URL for auth callbacks and absolute links.
NEXTAUTH_URL="http://localhost:3000"

# Shared auth/session signing secret. Use a long random value.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Base app URL used for notifications and generated links.
APP_URL="http://localhost:3000"

# Default admin bootstrap login. Used only for configured admin access flow.
ADMIN_EMAIL="admin@shaaradakoota.com"
ADMIN_PASSWORD="ChangeMe123!"

# Comma-separated operational school/front desk recipients.
FRONTDESK_EMAILS="frontdesk@shaaradakoota.com"

# Default sender email used by notification templates.
NOTIFICATION_FROM_EMAIL="noreply@shaaradakoota.com"

# SMTP credentials for email sending.
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp-user"
SMTP_PASSWORD="smtp-password"

# Notification provider toggles.
WHATSAPP_PROVIDER="disabled"
SMS_PROVIDER="disabled"

# Cloudinary storage credentials for uploaded media and documents.
CLOUDINARY_CLOUD_NAME="your-cloud"
CLOUDINARY_API_KEY="your-key"
CLOUDINARY_API_SECRET="your-secret"

# Razorpay public and private keys.
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="replace-me"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxx"
